<%- include('_layout/header') %>
<div class="container">
  <h2>My Progress</h2>

  <% if (user) { %>
    <h3>Progress Photos</h3>
    <% if (photos && photos.length > 0) { %>
      <div class="photo-gallery">
        <% photos.forEach(photo => { %>
          <div class="photo">
            <img src="/uploads/photos/<%= photo.imagePath %>" alt="Progress Photo" />
            <p><%= new Date(photo.date).toLocaleDateString() %></p>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <p>No progress photos uploaded yet.</p>
    <% } %>

    <h3>Weight Chart</h3>
    <%- include('partials/weightChart', { labels: weightChartLabels, weights: weightChartData }) %>
  <% } else { %>
    <p>User data not found. Please log in.</p>
  <% } %>
</div>
<%- include('_layout/footer') %>