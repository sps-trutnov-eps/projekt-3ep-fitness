<%- include('_layout/header') %>
<div class="container">
  <h2>Register</h2>
  <% if (locals.flashMessage) { %>
    <div class="flash-message <%= flashMessage.type %>" style="padding: 10px; margin-bottom: 15px; border-radius: 4px; 
         background-color: <%= flashMessage.type === 'error' ? '#FFEBEE' : 
                             flashMessage.type === 'success' ? '#E8F5E9' : 
                             flashMessage.type === 'warning' ? '#FFF3E0' : '#E3F2FD' %>; 
         color: <%= flashMessage.type === 'error' ? '#F44336' : 
                  flashMessage.type === 'success' ? '#4CAF50' : 
                  flashMessage.type === 'warning' ? '#FF9800' : '#2196F3' %>;">
      <%= flashMessage.message %>
      <button onclick="this.parentElement.style.display='none'" style="float:right; background: none; border: none; cursor: pointer;">×</button>
    </div>
  <% } %>

  <% if (locals.formErrors && locals.formErrors.form === 'registerForm') { %>
    <div class="flash-message error" style="padding: 10px; margin-bottom: 15px; border-radius: 4px; background-color: #FFEBEE; color: #F44336;">
      <%= formErrors.message %>
      <button onclick="this.parentElement.style.display='none'" style="float:right; background: none; border: none; cursor: pointer;">×</button>
    </div>
  <% } %>

  <form action="/user/register" method="POST">
    <div>
      <label for="username">Username:</label>
      <input type="text" name="username" id="username" required
             value="<%= locals.formData && formData.username ? formData.username : '' %>" />
    </div>
    <div>
      <label for="password">Password:</label>
      <input type="password" name="password" id="password" required />
    </div>
    <div>
      <label for="confirmPassword">Confirm Password:</label>
      <input
        type="password"
        name="confirmPassword"
        id="confirmPassword"
        required />
    </div>
    <button type="submit">Register</button>
  </form>
  <p>Already have an account? <a href="/user/login">Login here</a></p>
</div>
<%- include('_layout/footer') %>
